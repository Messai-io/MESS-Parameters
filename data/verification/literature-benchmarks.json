{
  "schema_version": "0.1.0",
  "description": "Curated p10-p90 benchmarks for headline MES parameters, used by scripts/verify/literature_crosscheck.ts. Sources: Logan 2008 (ES&T 42:8630), Rabaey & Rozendal 2010 (Nature Rev Microbiol 8:706), Santoro et al 2017 (J Power Sources 356:225), Pant et al 2010 (Bioresource Tech 101:1533). Ranges are deliberately generous to accommodate multi-system-type corpus.",
  "tolerance_notes": "p10/p90 are the lower/upper envelopes within which the corpus median must fall. Canonical units match scripts/verify/unit_families.ts. Corpus median outside [p10,p90] = FLAG; outside [p5,p95] = FAIL.",
  "benchmarks": [
    {
      "parameter_name": "power density",
      "canonical_unit": "mW/m²",
      "p10": 50,
      "p90": 5000,
      "p5": 10,
      "p95": 10000,
      "source": "Logan 2008 Table 2; Santoro 2017 Fig 4 (air-cathode MFCs)"
    },
    {
      "parameter_name": "current density",
      "canonical_unit": "mA/m²",
      "p10": 200,
      "p90": 20000,
      "p5": 50,
      "p95": 50000,
      "source": "Logan 2008; Rabaey & Rozendal 2010"
    },
    {
      "parameter_name": "coulombic efficiency",
      "canonical_unit": "%",
      "p10": 5,
      "p90": 80,
      "p5": 1,
      "p95": 95,
      "source": "Logan 2008 Eq 5; Pant 2010 Table 1"
    },
    {
      "parameter_name": "cod removal",
      "canonical_unit": "%",
      "p10": 40,
      "p90": 95,
      "p5": 20,
      "p95": 99,
      "source": "Pant 2010; Santoro 2017"
    },
    {
      "parameter_name": "voltage",

{
  "name": "@messai-io/mess-parameters",
  "version": "0.2.0",
  "description": "Standardized parameter ontology and analysis tools for Microbial Electrochemical Systems (MES) research — 687 parameters across 13 categories",
  "main": "parameters/index.json",
  "exports": {
    ".": {
      "import": "./parameters/index.json"
    },
    "./parameters": {
      "import": "./parameters/index.json"
    }
  },
  "files": [
    "parameters",
    "schemas",
    "data",
    "standards"
  ],
  "scripts": {
    "validate": "node scripts/validate.js",
    "export:csv": "npx tsx scripts/generate-csv-exports.ts",
    "generate:pages": "node scripts/generate-parameter-pages.js",
    "export:all": "npx tsx scripts/export-all-data.ts",
    "site:dev": "cd site && npm run dev",
    "site:build": "cd site && npm run build",
    "site:preview": "cd site && npm run preview"
  },
  "keywords": [
    "parameters",
    "standards",
    "mes",
    "mfc",
    "mec",
    "mdc",
    "microbial-fuel-cell",
    "microbial-electrolysis",
    "electrochemistry",
    "bioelectrochemistry",
    "fair-data",
    "reproducibility"
  ],
  "author": "MESSAI Community",
  "license": "CC-BY-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Messai-io/MESS-Parameters.git"
  },
  "homepage": "https://github.com/Messai-io/MESS-Parameters",
  "bugs": {
    "url": "https://github.com/Messai-io/MESS-Parameters/issues"
  }
}
